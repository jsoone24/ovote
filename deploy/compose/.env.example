# Copy to .env and adjust for your environment.

# Seeds the first admin account on API boot. Use the same email when signing
# in through the web UI to pick up the admin role.
OVOTE_ADMIN_BOOTSTRAP_EMAIL=admin@example.com

# memory = in-process bulletin board (good for UI demos and e2e tests)
# fabric = real Fabric gateway (requires deploy/fabric to be up)
OVOTE_CHAIN_DRIVER=memory

# Must match an entry from {2048, 3072, 4096}. 3072 is the default.
OVOTE_BLIND_RSA_MODULUS=3072

# Public base URL the web client uses to reach the API. Leave as-is for
# the default local compose setup.
VITE_OVOTE_API=http://localhost:3000

# SMTP mailer (optional). If unset the API logs OTP codes to stdout, which
# is fine for local dev but never OK in production.
# OVOTE_SMTP_URL=smtps://apikey:<token>@smtp.sendgrid.net:465
# OVOTE_SMTP_FROM=no-reply@yourdomain.example

# Master AES-256-GCM key used to encrypt per-agenda RSA blind-signing keys
# at rest. Generate with: `head -c 32 /dev/urandom | basenc --base64url -w0`.
# If unset the API writes one to <OVOTE_DB_PATH-dir>/secret.key (0600) on
# first boot. Multi-replica or ephemeral (k8s/pod) deployments MUST inject
# it explicitly — losing this key makes past blind-signing keys unrecoverable.
# OVOTE_SECRET_KEY=...base64url(32 bytes)...

# Comma-separated list of allowed CORS origins. Default "*" is fine for
# local dev; production must pin to the exact web UI origin(s).
# OVOTE_CORS_ORIGINS=https://vote.example.org

# Trust proxy headers. "false" (default) = never trust X-Forwarded-For.
# Set this only when running behind a proxy you control (e.g. a CIDR that
# matches your ingress), otherwise attackers can spoof IPs to bypass the
# rate limiter.
# OVOTE_TRUST_PROXY=10.0.0.0/8

# Fabric gateway — only consumed when OVOTE_CHAIN_DRIVER=fabric. Paths are
# inside the container; bind-mount deploy/fabric/crypto-config to expose
# them. See deploy/fabric/README.md for the full flow.
# OVOTE_FABRIC_CHANNEL=ovote-channel
# OVOTE_FABRIC_CHAINCODE=ovote
# OVOTE_FABRIC_MSP_ID=Org1MSP
# OVOTE_FABRIC_PEER_ENDPOINT=peer0.org1.ovote.local:7051
# OVOTE_FABRIC_PEER_HOSTNAME_OVERRIDE=peer0.org1.ovote.local
# OVOTE_FABRIC_TLS_ROOT_CERT=/fabric/peerOrganizations/org1.ovote.local/peers/peer0.org1.ovote.local/tls/ca.crt
# OVOTE_FABRIC_SIGNCERT=/fabric/peerOrganizations/org1.ovote.local/users/Admin@org1.ovote.local/msp/signcerts/Admin@org1.ovote.local-cert.pem
# OVOTE_FABRIC_KEYSTORE_DIR=/fabric/peerOrganizations/org1.ovote.local/users/Admin@org1.ovote.local/msp/keystore
